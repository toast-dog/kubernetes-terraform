# Cloudflare API token — requires Zone:DNS:Edit permission scoped to your domain
# Create at: Cloudflare Dashboard -> My Profile -> API Tokens
cloudflare_zones = {
  "toastdog.net" = "your-cloudflare-token-here"
}

# BGP authentication password for MetalLB <-> OPNsense FRR peering (TCP MD5)
# Must match proxmox-terraform/ansible/.secrets/bgp.key
metallb_bgp_password = "your-bgp-password-here"
